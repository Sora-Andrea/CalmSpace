<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Microphone permission for ambient noise monitoring -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    
    <!-- Foreground service permissions for background noise monitoring -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    
    <!-- Wake lock to prevent CPU sleep during monitoring -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Sleep scheduling: receive alarms + boot broadcast -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Exact alarms required for scheduled bedtime/wake on Android 12+ -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!-- Push notifications (required on Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CalmSpace">
        
        <activity
            android:name="com.calmspace.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.CalmSpace">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Noise monitoring foreground service -->
        <service
            android:name="com.calmspace.service.NoiseMonitorService"
            android:foregroundServiceType="microphone"
            android:exported="false" />

        <!-- Sleep schedule receiver: handles bedtime/wake alarms + boot reschedule -->
        <receiver
            android:name="com.calmspace.sleep.SleepScheduleReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.calmspace.ACTION_BEDTIME_REMINDER" />
                <action android:name="com.calmspace.ACTION_WAKE_STOP" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
